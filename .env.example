# .env.example for AI Incident Investigator

# LLM_MODE: 'mock' for local testing, 'bedrock' to use AWS Bedrock
LLM_MODE=mock  # Options: mock, bedrock

# DATABASE_URL: SQLAlchemy DB URL, e.g. 'sqlite:///./app.db' or 'postgresql://user:pass@host/db'
DATABASE_URL=sqlite:///./app.db

# BEDROCK_MODEL_ID: Claude model ID for AWS Bedrock (only needed if LLM_MODE=bedrock)
BEDROCK_MODEL_ID=anthropic.claude-v2

# AWS_REGION: AWS region for Bedrock
AWS_REGION=us-east-1

# AWS_ACCESS_KEY_ID: Your AWS access key (required for Bedrock)
AWS_ACCESS_KEY_ID=your-access-key-id

# AWS_SECRET_ACCESS_KEY: Your AWS secret key (required for Bedrock)
AWS_SECRET_ACCESS_KEY=your-secret-access-key
